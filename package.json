{
  "name": "yoya-basic",
  "version": "1.0.0",
  "description": "浏览器原生的 HTML DSL 库，提供类似 Kotlin HTML DSL 的声明式语法",
  "type": "module",
  "main": "src/yoya/index.js",
  "types": "src/yoya/index.d.ts",
  "scripts": {
    "dev": "vite",
    "serve": "node server.js",
    "start": "node server.js",
    "test": "node tests/basic.test.js",
    "test:browser": "playwright test",
    "test:browser:ui": "playwright test --ui",
    "test:browser:debug": "playwright test --debug",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "html",
    "dsl",
    "dom",
    "browser",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "jsdom": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
