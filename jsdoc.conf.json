{
  "source": {
    "include": ["src/yoya"],
    "includePattern": ".+\\.js$",
    "excludePattern": "(node_modules|tests|examples|v1|v2)"
  },
  "plugins": [],
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true,
    "default": {
      "outputSourceFiles": true,
      "includeDatePattern": true
    }
  },
  "opts": {
    "destination": "./docs",
    "encoding": "utf8",
    "recurse": true,
    "template": "./node_modules/jsdoc/templates/default",
    "readme": "./README.md"
  },
  "tags": {
    "allowUnknownTags": ["category", "subcategory"]
  }
}
